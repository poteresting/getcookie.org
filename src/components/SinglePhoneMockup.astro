---
interface Props {
  videoSrc: string;
  platform?: 'telegram' | 'discord';
  alt?: string;
  showLabel?: boolean;
}

const { videoSrc, platform = 'telegram', alt = 'Phone demo', showLabel = true } = Astro.props;
---

<div class="single-phone-showcase" data-active="none">
  <div class="phone phone-main" data-phone="main">
    <div class="phone-frame">
      <div class="phone-notch"></div>
      <div class="phone-screen">
        <video
          class="phone-video"
          src={videoSrc}
          loop
          muted
          playsinline
          preload="metadata"
        />
        <button class="play-button" data-phone="main" aria-label={`Play ${alt}`}>
          <svg class="icon-play" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <svg class="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
    {showLabel && (
      <span class="phone-label">
        {platform === 'telegram' ? (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#229ED9">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
        ) : (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#5865F2">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
          </svg>
        )}
      </span>
    )}
  </div>
</div>

<script>
  function initSinglePhoneShowcase() {
    document.querySelectorAll('.single-phone-showcase').forEach(showcase => {
      const playButton = showcase.querySelector('.play-button') as HTMLButtonElement;
      const phone = showcase.querySelector('.phone') as HTMLElement;
      const video = showcase.querySelector('.phone-video') as HTMLVideoElement;

      if (!playButton || !video || !phone) return;

      let lastInteractionTime = 0;
      let hideTimeout: ReturnType<typeof setTimeout> | null = null;

      // Force load first frame of video (fixes black screen on mobile)
      video.addEventListener('loadedmetadata', () => {
        video.currentTime = 0.001;
      });
      video.addEventListener('loadeddata', () => {
        if (video.currentTime === 0) {
          video.currentTime = 0.001;
        }
      });

      const isVideoPlaying = () => {
        const currentActive = showcase.getAttribute('data-active') || 'none';
        return currentActive === 'main' || currentActive === 'main-returning';
      };

      const isFullscreen = () => {
        const currentActive = showcase.getAttribute('data-active') || 'none';
        return currentActive === 'main-full';
      };

      const showButton = () => {
        if (hideTimeout) {
          clearTimeout(hideTimeout);
          hideTimeout = null;
        }
        playButton.classList.remove('mouse-idle');
        playButton.classList.remove('touch-idle');
      };

      const hideButtonAfterDelay = (delay = 1000) => {
        if (hideTimeout) {
          clearTimeout(hideTimeout);
        }
        hideTimeout = setTimeout(() => {
          if (isVideoPlaying() || isFullscreen()) {
            playButton.classList.add('mouse-idle');
            playButton.classList.add('touch-idle');
          }
          hideTimeout = null;
        }, delay);
      };

      const clearHideTimeout = () => {
        if (hideTimeout) {
          clearTimeout(hideTimeout);
          hideTimeout = null;
        }
      };

      (phone as any)._clearHideTimeout = clearHideTimeout;

      // Desktop: mouse movement tracking
      phone.addEventListener('mousemove', () => {
        if (isVideoPlaying()) {
          showButton();
          hideButtonAfterDelay(700);
        }
      });

      phone.addEventListener('mouseleave', () => {
        clearHideTimeout();
        if (isVideoPlaying()) {
          playButton.classList.add('mouse-idle');
        }
      });

      // Mobile: touch tracking for fullscreen X button
      phone.addEventListener('touchstart', () => {
        if (isFullscreen()) {
          showButton();
          hideButtonAfterDelay(900);
        }
      }, { passive: true });

      const handleInteraction = (e: Event) => {
        const now = Date.now();
        if (now - lastInteractionTime < 300) return;
        lastInteractionTime = now;

        e.preventDefault();
        e.stopPropagation();

        const currentActive = showcase.getAttribute('data-active') || 'none';
        const isMobileNow = window.innerWidth <= 480;

        const pauseVideo = () => {
          video.pause();
          video.currentTime = 0;
        };

        if (currentActive === 'none') {
          if (isMobileNow) {
            showcase.setAttribute('data-active', 'main');
            video.play();
            playButton.classList.add('just-clicked');
            playButton.classList.add('touch-idle');
            setTimeout(() => {
              showcase.setAttribute('data-active', 'main-full');
              playButton.classList.remove('just-clicked');
            }, 450);
          } else {
            showcase.setAttribute('data-active', 'main');
            video.play();
            playButton.classList.add('just-clicked');
            const onMouseMove = () => {
              playButton.classList.remove('just-clicked');
              document.removeEventListener('mousemove', onMouseMove);
            };
            document.addEventListener('mousemove', onMouseMove);
          }
        } else if (currentActive === 'main-full') {
          showcase.setAttribute('data-active', 'main-closing');
          pauseVideo();
          if ((phone as any)?._clearHideTimeout) (phone as any)._clearHideTimeout();
          playButton.classList.add('just-clicked');
          playButton.classList.remove('touch-idle');
          setTimeout(() => {
            showcase.setAttribute('data-active', 'none');
            playButton.classList.remove('just-clicked');
          }, 500);
        } else if (currentActive === 'main' || currentActive === 'main-returning') {
          if (isMobileNow) {
            showcase.setAttribute('data-active', 'main-full');
          } else {
            pauseVideo();
            if ((phone as any)?._clearHideTimeout) (phone as any)._clearHideTimeout();
            playButton.classList.remove('just-clicked');
            playButton.classList.remove('mouse-idle');
            showcase.setAttribute('data-active', 'none');
          }
        }
      };

      playButton.addEventListener('click', handleInteraction);
      playButton.addEventListener('touchend', handleInteraction, { passive: false });

      // Close video when clicking outside the phone
      const handleOutsideClick = (e: Event) => {
        const currentActive = showcase.getAttribute('data-active') || 'none';
        if (currentActive === 'none') return;

        // Check if click is on actual phone content (frame, screen, button, label)
        const clickedFrame = (e.target as Element).closest('.phone-frame');
        const clickedPlayBtn = (e.target as Element).closest('.play-button');
        const clickedLabel = (e.target as Element).closest('.phone-label');

        // Also check if click is within this showcase's container
        const clickedShowcase = (e.target as Element).closest('.single-phone-showcase');
        const isThisShowcase = clickedShowcase === showcase;

        // Close if clicked outside frame/button/label, OR if clicked on a different showcase
        if ((!clickedFrame && !clickedPlayBtn && !clickedLabel) || (clickedShowcase && !isThisShowcase)) {
          video.pause();
          video.currentTime = 0;

          if ((phone as any)._clearHideTimeout) (phone as any)._clearHideTimeout();

          playButton.classList.remove('just-clicked');
          playButton.classList.remove('mouse-idle');
          playButton.classList.remove('touch-idle');

          showcase.setAttribute('data-active', 'none');
        }
      };

      document.addEventListener('click', handleOutsideClick);
      document.addEventListener('touchstart', handleOutsideClick, { passive: true });
    });
  }

  initSinglePhoneShowcase();
  document.addEventListener('astro:after-swap', initSinglePhoneShowcase);
</script>

<style>
  .single-phone-showcase {
    position: relative;
    width: 100%;
    height: 580px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .phone {
    position: absolute;
    background: none;
    border: none;
    padding: 30px;
    margin: -30px;
    cursor: default;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    -webkit-tap-highlight-color: transparent;
  }

  .phone .phone-frame,
  .phone .phone-screen,
  .phone .phone-notch,
  .phone .phone-label {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .phone:focus {
    outline: none;
  }

  .phone:focus-visible .phone-frame {
    box-shadow: 0 0 0 3px var(--accent);
  }

  .phone-frame {
    position: relative;
    background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
    border-radius: 52px;
    padding: 12px;
    box-shadow:
      0 30px 60px -15px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.3);
    transition: box-shadow 0.5s ease;
  }

  .phone-notch {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: 105px;
    height: 30px;
    background: #000;
    border-radius: 15px;
    z-index: 10;
  }

  .phone-notch::after {
    content: '';
    position: absolute;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    width: 10px;
    height: 10px;
    background: #1a1a2e;
    border-radius: 50%;
    box-shadow: inset 0 0 2px rgba(0, 100, 255, 0.3);
  }

  .phone-screen {
    position: relative;
    width: 240px;
    height: 520px;
    background: #000;
    border-radius: 40px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .phone-screen video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .phone-video {
    background: #000;
  }

  .play-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.6);
    border: 2px solid rgba(255, 255, 255, 0.3);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease, border-color 0.3s ease, opacity 0.2s ease;
    z-index: 10;
    -webkit-tap-highlight-color: transparent;
  }

  .play-button svg {
    width: 44px;
    height: 44px;
    color: rgba(255, 255, 255, 0.8);
  }

  .play-button .icon-play {
    margin-left: 6px;
  }

  .play-button .icon-close {
    display: none;
  }

  .play-button:hover {
    background: rgba(0, 0, 0, 0.8);
    border-color: rgba(255, 255, 255, 0.5);
  }

  /* Desktop only: add scale on hover */
  @media (min-width: 481px) {
    .play-button {
      transition: background 0.3s ease, border-color 0.3s ease, opacity 0.2s ease, transform 0.3s ease;
    }

    .play-button:hover {
      transform: translate(-50%, -50%) scale(1.1);
    }
  }

  .play-button:hover svg {
    color: #fff;
  }

  /* When video is playing: hide button, show X on hover */
  .single-phone-showcase[data-active="main"] .play-button,
  .single-phone-showcase[data-active="main-returning"] .play-button {
    opacity: 0;
    pointer-events: none;
  }

  .single-phone-showcase[data-active="main"] .phone:hover .play-button:not(.just-clicked):not(.mouse-idle),
  .single-phone-showcase[data-active="main-returning"] .phone:hover .play-button:not(.just-clicked):not(.mouse-idle) {
    opacity: 1 !important;
    pointer-events: auto !important;
  }

  /* Hide button when mouse/touch is idle */
  .play-button.mouse-idle,
  .play-button.touch-idle {
    opacity: 0 !important;
    pointer-events: none !important;
  }

  /* Hide button immediately after click until mouse moves */
  .play-button.just-clicked {
    opacity: 0 !important;
    pointer-events: none !important;
  }

  /* Keep showing play icon (not X) while fading out */
  .play-button.just-clicked .icon-play {
    display: block !important;
  }

  .play-button.just-clicked .icon-close {
    display: none !important;
  }

  .single-phone-showcase[data-active="main"] .play-button .icon-play,
  .single-phone-showcase[data-active="main-returning"] .play-button .icon-play {
    display: none;
  }

  .single-phone-showcase[data-active="main"] .play-button .icon-close,
  .single-phone-showcase[data-active="main-returning"] .play-button .icon-close {
    display: block;
  }

  /* Hide play button in fullscreen states */
  .single-phone-showcase[data-active="main-full"] .play-button,
  .single-phone-showcase[data-active="main-closing"] .play-button {
    opacity: 0;
    pointer-events: none;
  }

  .phone-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--muted);
    transition: color 0.3s ease;
  }

  /* Default state: phone at slightly smaller scale */
  .phone-main {
    z-index: 2;
    transform: scale(0.95);
  }

  /* Default state: hover - scale up and add glow (like the original) */
  .single-phone-showcase[data-active="none"] .phone-main:hover {
    transform: scale(1.35);
  }

  .single-phone-showcase[data-active="none"] .phone-main:hover .phone-frame {
    box-shadow:
      0 35px 70px -15px rgba(0, 0, 0, 0.7),
      0 0 0 1px rgba(255, 255, 255, 0.15),
      0 0 40px rgba(88, 101, 242, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.3);
  }

  /* Active state: phone stays scaled with glow */
  .single-phone-showcase[data-active="main"] .phone-main,
  .single-phone-showcase[data-active="main"] .phone-main:hover {
    transform: scale(1.35);
  }

  .single-phone-showcase[data-active="main"] .phone-main .phone-frame,
  .single-phone-showcase[data-active="main"] .phone-main:hover .phone-frame {
    box-shadow:
      0 35px 70px -15px rgba(0, 0, 0, 0.7),
      0 0 0 1px rgba(255, 255, 255, 0.15),
      0 0 40px rgba(88, 101, 242, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.3);
  }

  /* Desktop fullscreen states (same as active) */
  .single-phone-showcase[data-active="main-full"] .phone-main {
    transform: scale(1.35);
  }

  .single-phone-showcase[data-active="main-full"] .phone-main .phone-frame {
    box-shadow:
      0 35px 70px -15px rgba(0, 0, 0, 0.7),
      0 0 0 1px rgba(255, 255, 255, 0.15),
      0 0 40px rgba(88, 101, 242, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.3);
  }

  /* Closing state */
  .single-phone-showcase[data-active="main-closing"] .phone-main {
    transform: scale(1.35);
  }

  .single-phone-showcase[data-active="main-closing"] .phone-main .phone-frame {
    box-shadow:
      0 35px 70px -15px rgba(0, 0, 0, 0.7),
      0 0 0 1px rgba(255, 255, 255, 0.15),
      0 0 40px rgba(88, 101, 242, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.3);
  }

  /* Returning state */
  .single-phone-showcase[data-active="main-returning"] .phone-main {
    transform: scale(1.35);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .single-phone-showcase {
      height: 480px;
    }

    .phone-frame {
      border-radius: 44px;
      padding: 10px;
    }

    .phone-notch {
      width: 85px;
      height: 24px;
      top: 14px;
      border-radius: 12px;
    }

    .phone-notch::after {
      width: 8px;
      height: 8px;
      right: 18px;
    }

    .phone-screen {
      width: 190px;
      height: 410px;
      border-radius: 34px;
    }
  }

  @media (max-width: 600px) {
    .single-phone-showcase {
      height: 400px;
    }

    .phone-frame {
      border-radius: 36px;
      padding: 8px;
    }

    .phone-notch {
      width: 70px;
      height: 20px;
      top: 12px;
      border-radius: 10px;
    }

    .phone-notch::after {
      width: 6px;
      height: 6px;
      right: 16px;
    }

    .phone-screen {
      width: 155px;
      height: 335px;
      border-radius: 28px;
    }
  }

  @media (max-width: 480px) {
    .single-phone-showcase {
      height: 340px;
      margin-top: 40px;
    }

    .phone-frame {
      border-radius: 22px;
      padding: 5px;
      transition: none !important;
    }

    .phone-screen {
      width: 90px;
      height: 195px;
      border-radius: 18px;
    }

    .phone-notch {
      width: 40px;
      height: 12px;
      top: 7px;
      border-radius: 6px;
    }

    .phone-notch::after {
      width: 4px;
      height: 4px;
      right: 9px;
    }

    .phone-label {
      font-size: 10px;
    }

    /* Smaller play button for mobile */
    .play-button {
      width: 50px;
      height: 50px;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      margin: auto;
      transform: none;
      transition: background 0.3s ease, border-color 0.3s ease, opacity 0.35s ease;
    }

    .play-button svg {
      width: 24px;
      height: 24px;
    }

    .play-button .icon-play {
      margin-left: 3px;
    }

    /* Reset desktop styles for mobile */
    .phone {
      padding: 0;
      margin: 0;
      will-change: transform;
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
      transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }

    /* Default: phone at larger scale on mobile */
    .single-phone-showcase[data-active="none"] .phone-main {
      transform: scale(1.5) !important;
    }

    /* No hover effect on mobile - keep same size */
    .single-phone-showcase[data-active="none"] .phone-main:hover {
      transform: scale(1.5) !important;
    }

    .single-phone-showcase[data-active="none"] .phone-main .phone-frame,
    .single-phone-showcase[data-active="none"] .phone-main:hover .phone-frame {
      box-shadow:
        0 30px 60px -15px rgba(0, 0, 0, 0.6),
        0 0 0 1px rgba(255, 255, 255, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        inset 0 -1px 0 rgba(0, 0, 0, 0.3);
    }

    /* Active state on mobile */
    .single-phone-showcase[data-active="main"] .phone-main {
      transform: scale(1.45) !important;
    }

    .single-phone-showcase[data-active="main"] .phone-main .phone-frame {
      box-shadow:
        0 30px 60px -15px rgba(0, 0, 0, 0.6),
        0 0 0 1px rgba(255, 255, 255, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        inset 0 -1px 0 rgba(0, 0, 0, 0.3);
    }

    /* Allow fullscreen phones to overflow container */
    .single-phone-showcase[data-active="main-full"] {
      overflow: visible;
    }

    /* Smooth transitions for fullscreen on mobile */
    .single-phone-showcase[data-active="main-full"] .phone,
    .single-phone-showcase[data-active="main-closing"] .phone {
      transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform;
    }

    /* Disable child element transitions during fullscreen */
    .single-phone-showcase[data-active="main-full"] .phone-frame,
    .single-phone-showcase[data-active="main-full"] .phone-screen,
    .single-phone-showcase[data-active="main-full"] .phone-notch,
    .single-phone-showcase[data-active="main-closing"] .phone-frame,
    .single-phone-showcase[data-active="main-closing"] .phone-screen,
    .single-phone-showcase[data-active="main-closing"] .phone-notch {
      transition: none !important;
    }

    /* Closing state on mobile */
    .single-phone-showcase[data-active="main-closing"] .phone-main {
      transform: scale(1.5) !important;
    }

    .single-phone-showcase[data-active="main-closing"] .phone-main .phone-frame {
      box-shadow:
        0 30px 60px -15px rgba(0, 0, 0, 0.6),
        0 0 0 1px rgba(255, 255, 255, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        inset 0 -1px 0 rgba(0, 0, 0, 0.3);
    }

    /* Mobile fullscreen */
    .single-phone-showcase[data-active="main-full"] .phone-main {
      z-index: 10;
      transform: scale(3.1) !important;
      cursor: pointer;
      pointer-events: auto;
    }

    .single-phone-showcase[data-active="main-full"] .phone-main .phone-frame {
      box-shadow:
        0 30px 60px -15px rgba(0, 0, 0, 0.6),
        0 0 0 1px rgba(255, 255, 255, 0.1),
