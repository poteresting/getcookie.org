---
interface Props {
  discordVideo?: string;
  telegramVideo?: string;
  discordComingSoon?: boolean;
}

const { discordVideo, telegramVideo, discordComingSoon } = Astro.props;
---

<div class="phone-showcase" data-active="none">
  <div class="phone phone-discord" data-phone="discord">
    <div class="phone-frame">
      <div class="phone-notch"></div>
      <div class="phone-screen">
        {discordComingSoon ? (
          <div class="phone-coming-soon">
