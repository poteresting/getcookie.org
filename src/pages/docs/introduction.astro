---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { LINKS } from '../../lib/constants';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<DocsLayout
	title="Introduction"
	description="Cookie is a community recognition app for Slack and Microsoft Teams. Give Cookies to members, earn crypto rewards, and build a culture of appreciation."
>
	<h1><img src={`${base}/logo.png`} alt="Cookie Logo" style="height: 1.2em; vertical-align: middle; margin-right: 0.5rem;" /> What is Cookie?</h1>
	<p class="lead">
		Cookie is a community recognition app for Slack and Microsoft Teams that makes appreciation fun and meaningful.
		Members reward each other with reactions and cookies — a playful way to celebrate contributions, climb the leaderboards, and build a culture of appreciation in your community or organization.
	</p>

	<h2>Key Features</h2>
	<ul>
		<li><strong>Community Recognition</strong> — Members reward each other with Cookies and by emoji reactions</li>
		<li><strong>Leaderboards</strong> — Celebrate top contributors and see who's making the biggest impact</li>
		<li><strong>Build Culture</strong> — Reinforce the values that make your community thrive</li>
		<li><strong>Get Rewards</strong> — Cookies are real crypto tokens that can be redeemed for rewards</li>
		<li><strong>Engagement Tracking</strong> — Track engagement trends and what drives your community</li>
	</ul>

	<h2>Essential Resources</h2>
	<ul class="resource-list">
		<li>
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none">
				<path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z" fill="#E01E5A"/>
				<path d="M8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312z" fill="#36C5F0"/>
				<path d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.27 0a2.528 2.528 0 0 1-2.522 2.521 2.528 2.528 0 0 1-2.521-2.521V2.522A2.528 2.528 0 0 1 15.165 0a2.528 2.528 0 0 1 2.521 2.522v6.312z" fill="#2EB67D"/>
				<path d="M15.165 18.956a2.528 2.528 0 0 1 2.521 2.522A2.528 2.528 0 0 1 15.165 24a2.528 2.528 0 0 1-2.521-2.522v-2.522h2.521zm0-1.27a2.528 2.528 0 0 1-2.521-2.522 2.528 2.528 0 0 1 2.521-2.521h6.313A2.528 2.528 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.521h-6.313z" fill="#ECB22E"/>
			</svg>
			<a href={LINKS.SLACK_APP} target="_blank" rel="noreferrer">Add Cookie to Slack</a>
		</li>
		<li>
			<img src={`${base}/teams.svg`} alt="Microsoft Teams" width="20" height="20" />
			<a href={LINKS.TEAMS_APP} target="_blank" rel="noreferrer">Add Cookie to Microsoft Teams</a>
		</li>
		<li>
			<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
				<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
			</svg>
			<a href={LINKS.TWITTER} target="_blank" rel="noreferrer">Follow on X (@GetCookieHQ)</a>
		</li>
		<li>
			<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
				<path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
			</svg>
			<a href="mailto:support@getcookie.org">support@getcookie.org</a>
		</li>
	</ul>

	<div class="callout">
		<p>
			<strong>💡 Note:</strong> Cookie is actively developed based on community feedback. Join our Discord Support Server to give feedback and suggestions.
		</p>
	</div>
</DocsLayout>
