---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Globe from '../components/Globe.astro';
import { LINKS } from '../lib/constants';
---

<Layout
	title="Best People Program on Slack and Microsoft Teams | Cookie"
	description="Give Cookies to recognize teammates. Earn crypto rewards. Build a culture of appreciation on Slack and Microsoft Teams."
	url="/"
>
	<div class="page">
		<header class="nav">
			<a class="brand" href="/" aria-label="Cookie home">
				<img class="brandLogo" src="/logo.png" width="128" height="85" alt="Cookie" />
				<span class="brandName">Cookie</span>
			</a>
			<div class="mobile-header-right">
				<ThemeToggle />
				<button class="hamburger" aria-label="Toggle menu" aria-expanded="false" id="hamburger-btn">
					<span class="hamburger-line"></span>
					<span class="hamburger-line"></span>
					<span class="hamburger-line"></span>
				</button>
			</div>
			<nav class="navLinks" id="nav-links" aria-label="Primary">
				<a class="navLink" href="#features">Features</a>
				<a class="navLink" href="#how-it-works">How it works</a>
				<a class="navLink" href="/docs/introduction/">Resources</a>
				<a class="navBtn" href="/platform">Start for free</a>
				<span class="desktop-theme-toggle">
					<ThemeToggle />
				</span>
			</nav>
		</header>
		<div class="mobile-overlay" id="mobile-overlay"></div>

		<main>
			<section class="hero">
				<!-- Floating Slack-style messages -->
				<div class="slack-message floating-left-1">
					<img class="slack-avatar" src="/avatars/emma.png" alt="" />
					<div class="slack-content">
						<div class="slack-header">
							<span class="slack-username">Emma Johnson</span>
							<span class="slack-timestamp">2:32 PM</span>
						</div>
						<div class="slack-text">Welcome to the team! 🚀</div>
					</div>
				</div>
				<div class="slack-message floating-left-2">
					<img class="slack-avatar" src="/avatars/kevin.png" alt="" />
					<div class="slack-content">
						<div class="slack-header">
							<span class="slack-username">Kevin Chen</span>
							<span class="slack-timestamp">3:47 PM</span>
						</div>
						<div class="slack-text">Thanks for the help! 🙏</div>
					</div>
				</div>
				<div class="slack-message floating-right-1">
					<img class="slack-avatar" src="/avatars/marcus.png" alt="" />
					<div class="slack-content">
						<div class="slack-header">
							<span class="slack-username">Marcus Williams</span>
							<span class="slack-timestamp">4:05 PM</span>
						</div>
						<div class="slack-text">This is awesome! 🎉</div>
					</div>
				</div>
				<div class="slack-message floating-right-2">
					<img class="slack-avatar" src="/avatars/nicole.png" alt="" />
					<div class="slack-content">
						<div class="slack-header">
							<span class="slack-username">Nicole Harris</span>
							<span class="slack-timestamp">4:21 PM</span>
						</div>
						<div class="slack-text">Let's catch up soon! 🍪</div>
					</div>
				</div>
				<div class="hero-content">
					<h1 class="title-main">
						🚀 Experience better <span class="hero-rotating-wrapper"><span class="hero-rotating-word hero-word-current">onboarding</span><span class="hero-rotating-word hero-word-next"></span></span>
					</h1>
					<p class="stats">
						Platform to understand teams better, onboard new employees<br/> and build real connections
					</p>

					<div class="cta-buttons">
						<a class="btn-slack btn-slack-hero" href={LINKS.SLACK_APP}>
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none">
								<path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z" fill="#E01E5A"/>
								<path d="M8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312z" fill="#36C5F0"/>
								<path d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.27 0a2.528 2.528 0 0 1-2.522 2.521 2.528 2.528 0 0 1-2.521-2.521V2.522A2.528 2.528 0 0 1 15.165 0a2.528 2.528 0 0 1 2.521 2.522v6.312z" fill="#2EB67D"/>
								<path d="M15.165 18.956a2.528 2.528 0 0 1 2.521 2.522A2.528 2.528 0 0 1 15.165 24a2.528 2.528 0 0 1-2.521-2.522v-2.522h2.521zm0-1.27a2.528 2.528 0 0 1-2.521-2.522 2.528 2.528 0 0 1 2.521-2.521h6.313A2.528 2.528 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.521h-6.313z" fill="#ECB22E"/>
							</svg>
							Get Started for Free
						</a>
						<a class="btn-teams btn-teams-hero" href={LINKS.TEAMS_APP}>
							<img src="/teams.svg" alt="Microsoft Teams" width="28" height="28" />
							Get Started for Free
						</a>
					</div>

					<div class="hero-description">
						<span class="hero-tagline">Start Strong <svg class="tagline-star" width="19" height="19" viewBox="0 0 24 24" fill="#b5742d" style="vertical-align: -2px; margin: 0 2px;"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg> Stay Strong</span>
						<p>Your team is tired of being force-fed donuts and tacos, but... <br/>🍪 Cookie can help! <br class="br-mobile"/><span class="hero-kickoff">Kick off happier teams now with</span><br class="br-keep"/><span class="hero-platform-inline"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z" fill="#E01E5A"/><path d="M8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312z" fill="#36C5F0"/><path d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.27 0a2.528 2.528 0 0 1-2.522 2.521 2.528 2.528 0 0 1-2.521-2.521V2.522A2.528 2.528 0 0 1 15.165 0a2.528 2.528 0 0 1 2.521 2.522v6.312z" fill="#2EB67D"/><path d="M15.165 18.956a2.528 2.528 0 0 1 2.521 2.522A2.528 2.528 0 0 1 15.165 24a2.528 2.528 0 0 1-2.521-2.522v-2.522h2.521zm0-1.27a2.528 2.528 0 0 1-2.521-2.522 2.528 2.528 0 0 1 2.521-2.521h6.313A2.528 2.528 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.521h-6.313z" fill="#ECB22E"/></svg></span> <strong>Slack</strong> and <span class="hero-platform-inline"><img src="/teams.svg" alt="Microsoft Teams" width="20" height="20" /></span> <strong>Microsoft Teams</strong></p>
					</div>

					<!-- Mobile only card -->
					<div class="mobile-hero-card">
						<img class="slack-avatar" src="/avatars/marcus.png" alt="" />
						<div class="slack-content">
							<div class="slack-header">
								<span class="slack-username">Marcus Williams</span>
								<span class="slack-timestamp">4:05 PM</span>
							</div>
							<div class="slack-text">This is awesome! 🎉</div>
						</div>
					</div>

				</div>
			</section>

			<section class="showcase" id="features">
				<header class="features-header">
					<span class="section-label">Core features</span>
					<h2>🥇 Start Recognition</h2>
				</header>
				<article class="showcase-item">
					<div class="showcase-image showcase-card">
						<div class="discord-panel member-list standout-panel">
							<div class="role-group">
								<span class="role-header" style="color: #fbbf24;">🏆 MVP — 1</span>
								<div class="panel-user bubble-user">
									<span class="status-dot online"></span>
									<img class="avatar" src="/avatars/taylor.jpg" alt="" />
									<div class="user-info">
										<span class="username" style="color: #fbbf24;">Taylor</span>
									</div>
									<div class="chat-bubble-pop bubble-1">
										<span class="chat-bubble">Lets gooo! 🔥</span>
									</div>
								</div>
							</div>
							<div class="role-group">
								<span class="role-header" style="color: #22c55e;">🧙 Wizard — 1</span>
								<div class="panel-user bubble-user">
									<span class="status-dot online"></span>
									<img class="avatar" src="/avatars/jake.jpg" alt="" />
									<div class="user-info">
										<span class="username" style="color: #22c55e;">Jake</span>
									</div>
									<div class="chat-bubble-pop bubble-2">
										<span class="chat-bubble">You're welcome 😊</span>
									</div>
								</div>
							</div>
							<div class="role-group">
								<span class="role-header" style="color: #f472b6;">🗿 Memester — 1</span>
								<div class="panel-user bubble-user">
									<span class="status-dot online"></span>
									<img class="avatar" src="/avatars/mike.jpg" alt="" />
									<div class="user-info">
										<span class="username" style="color: #f472b6;">Mike</span>
									</div>
									<div class="chat-bubble-pop bubble-3">
										<span class="chat-bubble">I'm here for the cookies 🍪</span>
									</div>
								</div>
							</div>
						</div>
					</div>
					<div class="showcase-content">
						<div class="showcase-header">
						<div class="feature-icon cookie-icon">
							🤩
						</div>
						<h2>Stand Out</h2>
					</div>
						<p>Members get special badge for being most helpful, funniest and MVP based on emoji reactions to their messages. The recognition appears in a special place, as shown in the workspace.</p>
						<div class="showcase-buttons">
							<a class="btn-slack-sm" href={LINKS.SLACK_APP} target="_blank" rel="noreferrer">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none">
									<path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z" fill="#E01E5A"/>
									<path d="M8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312z" fill="#36C5F0"/>
									<path d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.27 0a2.528 2.528 0 0 1-2.522 2.521 2.528 2.528 0 0 1-2.521-2.521V2.522A2.528 2.528 0 0 1 15.165 0a2.528 2.528 0 0 1 2.521 2.522v6.312z" fill="#2EB67D"/>
									<path d="M15.165 18.956a2.528 2.528 0 0 1 2.521 2.522A2.528 2.528 0 0 1 15.165 24a2.528 2.528 0 0 1-2.521-2.522v-2.522h2.521zm0-1.27a2.528 2.528 0 0 1-2.521-2.522 2.528 2.528 0 0 1 2.521-2.521h6.313A2.528 2.528 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.521h-6.313z" fill="#ECB22E"/>
								</svg>
								Add to Slack
							</a>
						</div>
					</div>
				</article>

				<article class="showcase-item reversed">
					<div class="showcase-image showcase-card">
						<div class="discord-panel gratitude-panel">
							<div class="gratitude-earned">
								<span class="earned-badge">🍪 +7</span>
								<span class="earned-badge">🍪 +1</span>
							</div>
							<div class="gratitude-message">
								<img class="gratitude-avatar" src="/avatars/jake.jpg" alt="" />
								<div class="gratitude-content">
									<div class="gratitude-header">
										<span class="gratitude-username" style="color: #22c55e;">Jake</span>
										<span class="gratitude-timestamp">Today at 14:30</span>
									</div>
									<div class="gratitude-text">Here check this out guys</div>
									<div class="gratitude-reactions">
										<span class="reaction active">🍪 7</span>
										<span class="reaction">🙏 3</span>
										<span class="reaction">🫡 2</span>
									</div>
								</div>
							</div>
							<div class="gratitude-message">
								<img class="gratitude-avatar" src="/avatars/emma.png" alt="" />
								<div class="gratitude-content">
									<div class="gratitude-header">
										<span class="gratitude-username" style="color: #f472b6;">Emma</span>
										<span class="gratitude-timestamp">Today at 14:32</span>
									</div>
									<div class="gratitude-text">Thanks <span class="discord-mention">@Jake</span>! 🍪</div>
									<div class="gratitude-reactions">
										<span class="reaction">👍 1</span>
									</div>
								</div>
							</div>
						</div>
					</div>
					<div class="showcase-content">
						<div class="showcase-header">
						<div class="feature-icon cookie-icon">
							🙏
						</div>
						<h2>Show Gratitude</h2>
					</div>
						<p>React and reward with cookie or your favorite emojis to show appreciation to others. Fun and playful way to recognize helpful members. Cookie is now customizable to other reactions</p>
						<div class="showcase-buttons">
							<a class="btn-slack-sm" href={LINKS.SLACK_APP} target="_blank" rel="noreferrer">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none">
									<path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z" fill="#E01E5A"/>
									<path d="M8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312z" fill="#36C5F0"/>
									<path d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.27 0a2.528 2.528 0 0 1-2.522 2.521 2.528 2.528 0 0 1-2.521-2.521V2.522A2.528 2.528 0 0 1 15.165 0a2.528 2.528 0 0 1 2.521 2.522v6.312z" fill="#2EB67D"/>
									<path d="M15.165 18.956a2.528 2.528 0 0 1 2.521 2.522A2.528 2.528 0 0 1 15.165 24a2.528 2.528 0 0 1-2.521-2.522v-2.522h2.521zm0-1.27a2.528 2.528 0 0 1-2.521-2.522 2.528 2.528 0 0 1 2.521-2.521h6.313A2.528 2.528 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.521h-6.313z" fill="#ECB22E"/>
								</svg>
								Add to Slack
							</a>
						</div>
					</div>
				</article>

				<article class="showcase-item">
					<div class="showcase-image showcase-card">
						<div class="discord-panel fortune-panel">
							<div class="fortune-cookie-visual">
								<div class="fortune-cookie">🥠</div>
								<div class="fortune-message">
									<div class="fortune-paper">
										<span class="fortune-text">"You make a bigger difference than you know"</span>
									</div>
								</div>
							</div>
							<div class="fortune-share">
								<img class="gratitude-avatar" src="/avatars/mike.jpg" alt="" />
								<div class="fortune-share-content">
									<span class="fortune-share-text"><strong style="color: #fbbf24;">Mike</strong> has sent you a fortune cookie</span>
									<div class="gratitude-reactions">
										<span class="reaction reaction-animate reaction-1">❤️ 1</span>
										<span class="reaction reaction-animate reaction-2">✨ 1</span>
										<span class="reaction reaction-animate reaction-3">🙌 1</span>
									</div>
								</div>
							</div>
						</div>
					</div>
					<div class="showcase-content">
						<div class="showcase-header">
						<div class="feature-icon cookie-icon">
							🌟
						</div>
						<h2>Share Positivity</h2>
					</div>
						<p>A few members get a fortune cookie once a day with best wishes. Share these wishes with someone else to spread positivity and strengthen team connections.</p>
						<div class="showcase-buttons">
							<a class="btn-slack-sm" href={LINKS.SLACK_APP} target="_blank" rel="noreferrer">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none">
									<path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z" fill="#E01E5A"/>
									<path d="M8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312z" fill="#36C5F0"/>
									<path d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.27 0a2.528 2.528 0 0 1-2.522 2.521 2.528 2.528 0 0 1-2.521-2.521V2.522A2.528 2.528 0 0 1 15.165 0a2.528 2.528 0 0 1 2.521 2.522v6.312z" fill="#2EB67D"/>
									<path d="M15.165 18.956a2.528 2.528 0 0 1 2.521 2.522A2.528 2.528 0 0 1 15.165 24a2.528 2.528 0 0 1-2.521-2.522v-2.522h2.521zm0-1.27a2.528 2.528 0 0 1-2.521-2.522 2.528 2.528 0 0 1 2.521-2.521h6.313A2.528 2.528 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.521h-6.313z" fill="#ECB22E"/>
								</svg>
								Add to Slack
							</a>
						</div>
					</div>
				</article>
			</section>

			<section class="why-section" id="why">
				<header class="why-header">
					<span class="section-label">The fun way to boost engagement</span>
					<h2>Why use Cookie?</h2>
					<p class="section-desc">Communities using Cookie have built stronger connections and boosted engagement. Cookie makes recognition fun and rewarding.</p>
				</header>

				<div class="why-cards">
					<article class="why-card">
						<div class="why-spotlight"></div>
						<h3><span class="why-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg></span><span>Brings everyone <span class="highlight">together</span></span></h3>
						<p>Even if your members are spread across the globe or sitting at home, Cookie makes everyone feel connected by creating a positive environment.</p>
					</article>

					<article class="why-card">
						<div class="why-spotlight"></div>
