	<script is:inline>
		const TWEET_URL = 'https://twitter.com/GetCookieHQ';

		function initTweetEmbed() {
			const container = document.getElementById('twitter-container');
			if (!container) return;

			const theme = document.documentElement.getAttribute('data-theme') || 'light';

			// Clear and rebuild the blockquote with correct theme
			const linkColor = theme === 'dark' ? '#fff' : '#000';
			container.innerHTML = `
				<blockquote class="twitter-tweet" data-dnt="true" data-theme="${theme}" style="text-align: center; margin: 0; padding: 20px;">
					<a href="${TWEET_URL}" style="color: ${linkColor}; text-decoration: none;">Loading tweet...</a>
				</blockquote>
			`;

			// Load Twitter widget
			if (window.twttr && window.twttr.widgets) {
				window.twttr.widgets.load(container);
			}
		}

		// Initialize on load
		initTweetEmbed();

		// Re-initialize on Astro page transitions
		document.addEventListener('astro:after-swap', initTweetEmbed);

		// Re-initialize when theme changes
		const observer = new MutationObserver((mutations) => {
			mutations.forEach((mutation) => {
				if (mutation.attributeName === 'data-theme') {
					initTweetEmbed();
				}
			});
		});
		observer.observe(document.documentElement, { attributes: true });

		// Spotlight effect for feature cards and why cards
		function initSpotlight() {
			const cards = document.querySelectorAll('.feature-card, .why-card');

			cards.forEach(card => {
				card.addEventListener('mousemove', (e) => {
					const rect = card.getBoundingClientRect();
					const x = e.clientX - rect.left;
					const y = e.clientY - rect.top;

					card.style.setProperty('--mouse-x', `${x}px`);
					card.style.setProperty('--mouse-y', `${y}px`);
				});
			});
		}

		initSpotlight();
		document.addEventListener('astro:after-swap', initSpotlight);

		// Cookie counter animation for leaderboard
		function initCookieCounters() {
			const counters = document.querySelectorAll('.cookie-count');
			if (!counters.length) return;

			function animateCounters() {
				const taylorBubble = document.getElementById('taylor-yay');
				if (taylorBubble) taylorBubble.classList.remove('show');

				counters.forEach((counter, index) => {
					const target = parseInt(counter.getAttribute('data-target') || '1');
					let current = 1;
					const stepTime = 50; // Update every 50ms
					const increment = 3; // Increment by 3 each step

					counter.textContent = '1';

					const interval = setInterval(() => {
						current += increment;
						if (current >= target) {
							counter.textContent = target.toString();
							clearInterval(interval);
							// Show Taylor's "Yay!" when first counter (94) reaches target
							if (index === 0 && taylorBubble) {
								setTimeout(() => {
									taylorBubble.classList.add('show');
								}, 500);
							}
						} else {
							counter.textContent = current.toString();
						}
					}, stepTime);
				});
			}

			// Initial animation
			animateCounters();

			// Loop: reset and animate again every 4 seconds
			setInterval(() => {
				animateCounters();
			}, 4000);
		}

		initCookieCounters();
		document.addEventListener('astro:after-swap', initCookieCounters);

		// Typewriter effect for second command
		function initTypewriter() {
			var textElement = document.querySelector('.typewriter-text');
			if (!textElement) return;

			const fullText = '/cookie fortune-cookie disable';
			const cmdEnd = 7; // "/cookie" length
			const argEnd = 22; // "/cookie fortune-cookie" length
			let charIndex = 0;
			const typingSpeed = 80;
			const pauseBetweenLoops = 2000;
			const el = textElement;

			function typeChar() {
				if (charIndex <= fullText.length) {
					let displayText = '';
					const currentText = fullText.substring(0, charIndex);

					// Apply colors based on position
					if (charIndex <= cmdEnd) {
						displayText = '<span style="color:#5865f2;font-weight:600">' + currentText + '</span>';
					} else if (charIndex <= argEnd) {
						displayText = '<span style="color:#5865f2;font-weight:600">/cookie</span> <span style="color:#b9bbbe;font-weight:500">' + currentText.substring(cmdEnd + 1) + '</span>';
					} else {
						displayText = '<span style="color:#5865f2;font-weight:600">/cookie</span> <span style="color:#b9bbbe;font-weight:500">fortune-cookie</span> <span style="color:#b9bbbe;font-weight:500">' + currentText.substring(argEnd + 1) + '</span>';
					}

					el.innerHTML = displayText;
					charIndex++;
					setTimeout(typeChar, typingSpeed);
				} else {
					// Finished typing, wait then restart
					setTimeout(() => {
						charIndex = 0;
						el.innerHTML = '';
						setTimeout(typeChar, 500);
					}, pauseBetweenLoops);
				}
			}

			typeChar();
		}

		// Run typewriter on DOM ready
		document.addEventListener('DOMContentLoaded', function() {
			setTimeout(initTypewriter, 100);
		});
		document.addEventListener('astro:after-swap', initTypewriter);

		// Hero rotating word effect with crossfade
		function initHeroRotatingWord() {
			const words = ['onboarding', 'connections', 'recognition'];
			const els = document.querySelectorAll('.hero-rotating-word');
			if (els.length < 2) return;

			let wordIndex = 0;
			let activeIndex = 0;
			const displayTime = 1350;

			function rotateWord() {
				wordIndex = (wordIndex + 1) % words.length;
				const nextIndex = activeIndex === 0 ? 1 : 0;

				els[nextIndex].textContent = words[wordIndex];
				els[activeIndex].style.opacity = '0';
				els[nextIndex].style.opacity = '1';

				activeIndex = nextIndex;
			}

			setInterval(rotateWord, displayTime);
		}

		document.addEventListener('DOMContentLoaded', function() {
			setTimeout(initHeroRotatingWord, 100);
		});
		document.addEventListener('astro:after-swap', initHeroRotatingWord);

	</script>
	<script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
	<script is:inline>
		// Hamburger menu - separate script to ensure it runs
		document.addEventListener('DOMContentLoaded', function() {
			var hamburger = document.getElementById('hamburger-btn');
			var navLinks = document.getElementById('nav-links');
			var overlay = document.getElementById('mobile-overlay');

			if (!hamburger || !navLinks) return;

			function closeMenu() {
				hamburger.classList.remove('active');
				navLinks.classList.remove('open');
				if (overlay) overlay.classList.remove('active');
				hamburger.setAttribute('aria-expanded', 'false');
				document.body.style.overflow = '';
			}

			hamburger.addEventListener('click', function() {
				var isOpen = navLinks.classList.contains('open');
				hamburger.classList.toggle('active', !isOpen);
				navLinks.classList.toggle('open', !isOpen);
				if (overlay) overlay.classList.toggle('active', !isOpen);
				hamburger.setAttribute('aria-expanded', String(!isOpen));
				document.body.style.overflow = isOpen ? '' : 'hidden';
			});

			if (overlay) {
				overlay.addEventListener('click', closeMenu);
			}

			var links = navLinks.querySelectorAll('.navLink, .navBtn');
			for (var i = 0; i < links.length; i++) {
				links[i].addEventListener('click', closeMenu);
			}

			document.addEventListener('keydown', function(e) {
				if (e.key === 'Escape' && navLinks.classList.contains('open')) {
					closeMenu();
				}
			});
		});
	</script>
