	.chat-bubble-pop {
		position: absolute;
		top: 50%;
		right: -10px;
		transform: translateY(-50%);
		z-index: 10;
		white-space: nowrap;
	}

	.bubble-1 .chat-bubble {
		animation: chat-bubble-pop 6s ease-out infinite;
		animation-delay: 0s;
	}

	.bubble-2 .chat-bubble {
		animation: chat-bubble-pop 6s ease-out infinite;
		animation-delay: 2s;
	}

	.bubble-3 .chat-bubble {
		animation: chat-bubble-pop 6s ease-out infinite;
		animation-delay: 4s;
	}

	.chat-bubble {
		display: inline-block;
		background: #36393f;
		color: #dcddde;
		font-size: 13px;
		padding: 8px 12px;
		border-radius: 8px;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
		animation: chat-bubble-pop 3.5s ease-out infinite;
	}

	@keyframes chat-bubble-pop {
		0% {
			transform: scale(0.5) translateY(10px);
			opacity: 0;
		}
		8% {
			transform: scale(1.05) translateY(0);
			opacity: 1;
		}
		12% {
			transform: scale(1) translateY(0);
			opacity: 1;
		}
		28% {
			transform: scale(1) translateY(-5px);
			opacity: 1;
		}
		38% {
			transform: scale(0.95) translateY(-12px);
			opacity: 0;
		}
		100% {
			transform: scale(0.5) translateY(-12px);
			opacity: 0;
		}
	}

	@keyframes bubble-pop {
		0% {
			transform: translateY(20px) scale(0.8);
			opacity: 0;
		}
		8% {
			transform: translateY(15px) scale(1.1);
			opacity: 1;
		}
		12% {
			transform: translateY(15px) scale(1);
			opacity: 1;
		}
		35% {
			transform: translateY(-5px) scale(1);
			opacity: 1;
		}
		50% {
			transform: translateY(-20px) scale(0.8);
			opacity: 0;
		}
		100% {
			transform: translateY(-20px) scale(0.8);
			opacity: 0;
		}
	}

