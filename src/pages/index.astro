	@keyframes reactionPop1 {
		0% {
			opacity: 0;
			transform: scale(0.5);
		}
		10% {
			opacity: 1;
			transform: scale(1.15);
		}
		15%, 75% {
			opacity: 1;
			transform: scale(1);
		}
		85%, 100% {
			opacity: 0;
			transform: scale(0.5);
		}
	}

	@keyframes reactionPop2 {
		0%, 15% {
			opacity: 0;
			transform: scale(0.5);
		}
		25% {
			opacity: 1;
			transform: scale(1.15);
		}
		30%, 75% {
			opacity: 1;
			transform: scale(1);
		}
		85%, 100% {
			opacity: 0;
			transform: scale(0.5);
		}
	}

	@keyframes reactionPop3 {
		0%, 30% {
			opacity: 0;
			transform: scale(0.5);
		}
		40% {
			opacity: 1;
			transform: scale(1.15);
		}
		45%, 75% {
