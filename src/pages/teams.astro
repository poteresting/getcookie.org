---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { LINKS } from '../lib/constants';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Microsoft Teams — Coming Soon — Cookie" description="Cookie for Microsoft Teams is coming soon. Join the waitlist to be the first to know when it launches.">
	<div class="platform-page">
		<header class="platform-nav">
			<a class="brand" href={`${base}/`} aria-label="Cookie home">
				<img class="brandLogo" src={`${base}/logo.png`} width="128" height="85" alt="Cookie" />
				<span class="brandName">Cookie</span>
			</a>
			<nav class="navLinks" aria-label="Primary">
				<a class="navLink" href={`${base}/`}>Home</a>
				<ThemeToggle />
			</nav>
		</header>
		<div class="platform-card">
			<div class="platform-content">
				<div class="platform-left">
					<div class="coming-soon-badge">Coming Soon</div>

					<h1>Cookie for <span class="highlight">Microsoft Teams</span></h1>
					<p class="platform-subtitle">Be the first to know when Cookie launches on Teams.<br class="desktop-only"/> <strong>Join the waitlist</strong></p>

					<form class="waitlist-form" id="waitlist-form">
						<div class="form-group">
							<input
								type="email"
								name="email"
								placeholder="Enter your email"
								required
								class="email-input"
								id="email-input"
							/>
							<button type="submit" class="submit-btn" id="submit-btn">
								<span class="btn-text">Join Waitlist</span>
								<span class="btn-loading" style="display: none;">
									<svg class="spinner" width="20" height="20" viewBox="0 0 24 24" fill="none">
										<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-dasharray="32" stroke-dashoffset="32">
											<animate attributeName="stroke-dashoffset" values="32;0" dur="1s" repeatCount="indefinite" />
											<animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="1s" repeatCount="indefinite" />
										</circle>
									</svg>
								</span>
							</button>
						</div>
						<p class="form-note">We respect your privacy. No spam, ever.</p>
					</form>

					<div class="success-message" id="success-message" style="display: none;">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
							<circle cx="12" cy="12" r="10" fill="#22c55e"/>
							<path d="M8 12l2.5 2.5L16 9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
						<span>You're on the list! We'll be in touch soon.</span>
					</div>

					<div class="warning-message" id="error-message" style="display: none;">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
							<path d="M12 9v4" stroke="#f59e0b" stroke-width="2" stroke-linecap="round"/>
							<circle cx="12" cy="16" r="1" fill="#f59e0b"/>
							<circle cx="12" cy="12" r="9" stroke="#f59e0b" stroke-width="2"/>
						</svg>
						<span id="error-text">Something went wrong. Please try again.</span>
					</div>

					<p class="platform-note">Already using Slack? <a href={LINKS.SLACK_APP} class="slack-link">Get Cookie for Slack</a></p>
				</div>

			</div>
		</div>

		<footer class="footer">
			<div class="footer-inner">
				<div class="footer-grid">
					<div class="footer-col">
						<h4>About</h4>
						<a href={`${base}/docs/introduction/`}>Introduction</a>
						<a href={`${base}/docs/getting-started/setup/`}>Getting Started</a>
					</div>
					<div class="footer-col">
						<h4>Resources</h4>
						<a href={`${base}/docs/introduction/`}>Documentation</a>
						<a href={`${base}/docs/getting-started/need-help/`}>Help</a>
						<a href={`${base}/docs/getting-started/faq/`}>FAQ</a>
					</div>
					<div class="footer-col">
						<h4>Legal</h4>
						<a href={`${base}/docs/legal/privacy-policy/`}>Privacy Policy</a>
						<a href={`${base}/docs/legal/terms-of-service/`}>Terms of Service</a>
					</div>
					<div class="footer-col footer-brand">
						<a class="footer-logo" href={`${base}/`} aria-label="Cookie home">
							<img src={`${base}/logo.png`} width="128" height="85" alt="Cookie" />
							<span class="footer-brandName">Cookie</span>
						</a>
						<div class="footer-socials">
							<a href={LINKS.TWITTER} target="_blank" rel="noreferrer" aria-label="X (Twitter)">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
									<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
								</svg>
							</a>
						</div>
					</div>
				</div>
			</div>
		</footer>
	</div>
</Layout>

<script>
	const form = document.getElementById('waitlist-form') as HTMLFormElement;
	const emailInput = document.getElementById('email-input') as HTMLInputElement;
	const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
	const btnText = submitBtn.querySelector('.btn-text') as HTMLSpanElement;
	const btnLoading = submitBtn.querySelector('.btn-loading') as HTMLSpanElement;
	const successMessage = document.getElementById('success-message') as HTMLDivElement;
	const errorMessage = document.getElementById('error-message') as HTMLDivElement;
	const errorText = document.getElementById('error-text') as HTMLSpanElement;

	form.addEventListener('submit', async (e) => {
		e.preventDefault();

		const email = emailInput.value.trim();
		if (!email) return;

		// Show loading state
		btnText.style.display = 'none';
		btnLoading.style.display = 'inline-flex';
		submitBtn.disabled = true;
		errorMessage.style.display = 'none';

		try {
			// TODO: Replace with your actual API endpoint
			const response = await fetch('/api/waitlist', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify({ email, platform: 'teams' }),
			});

			if (!response.ok) {
				throw new Error('Failed to join waitlist');
			}

			// Show success
			form.style.display = 'none';
			successMessage.style.display = 'flex';
		} catch (error) {
			// Show error
			errorText.textContent = 'Something went wrong. Please try again.';
			errorMessage.style.display = 'flex';
		} finally {
			// Reset loading state
			btnText.style.display = 'inline';
			btnLoading.style.display = 'none';
			submitBtn.disabled = false;
		}
	});
</script>

<style>
	.mobile-only {
		display: none;
	}

	.platform-page {
		min-height: 100vh;
		background: var(--bg-secondary);
		display: flex;
		flex-direction: column;
	}

	.platform-nav {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 18px 24px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		text-decoration: none;
		color: var(--text);
	}

	.brandLogo {
		height: 30px;
		width: auto;
		display: block;
		border-radius: 8px;
	}

	.brandName {
		font-family: 'Nunito', sans-serif;
		font-size: 24px;
		font-weight: 800;
		font-style: italic;
		color: var(--text);
	}

	.navLinks {
		display: inline-flex;
		gap: 10px;
		align-items: center;
	}

	.navLink {
		color: var(--muted);
		text-decoration: none;
		padding: 8px 10px;
		border-radius: 999px;
		font-size: 14px;
	}

	.navLink:hover {
		background: var(--hover-bg);
		color: var(--text);
	}

	.platform-card {
		flex: 1;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding: 40px 24px 80px;
	}

	.platform-content {
		background: var(--bg);
		border-radius: 24px;
		padding: 60px;
		max-width: 700px;
		width: 100%;
		box-shadow: var(--shadow);
		text-align: center;
	}

	.coming-soon-badge {
		display: inline-block;
		background: linear-gradient(135deg, #b5742d, #c9864a);
		color: white;
		padding: 8px 20px;
		border-radius: 20px;
		font-size: 14px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 24px;
	}

	.platform-left h1 {
		font-size: 42px;
		font-weight: 800;
		line-height: 1.1;
		color: var(--text);
		margin: 0 0 16px;
	}

	.platform-left h1 .highlight {
		color: #b5742d;
	}

	.platform-subtitle {
		font-size: 18px;
		color: var(--muted);
		margin: 0 0 32px;
		line-height: 1.6;
	}

	.waitlist-form {
		max-width: 400px;
		margin: 0 auto;
	}

	.form-group {
		display: flex;
		gap: 12px;
	}

	.email-input {
		flex: 1;
		padding: 14px 18px;
		border: 2px solid var(--border);
		border-radius: 12px;
		font-size: 16px;
		background: var(--bg);
		color: var(--text);
		transition: border-color 0.2s ease;
	}

	.email-input:focus {
		outline: none;
		border-color: #b5742d;
	}

	.email-input::placeholder {
		color: var(--muted);
	}

	.submit-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		padding: 14px 24px;
		border-radius: 12px;
		font-size: 16px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.2s ease;
		background: #b87f3a;
		color: white;
		border: none;
		cursor: pointer;
		white-space: nowrap;
	}

	.submit-btn:hover:not(:disabled) {
		background: #c9935a;
		transform: translateY(-2px);
	}

	.submit-btn:disabled {
		opacity: 0.7;
		cursor: not-allowed;
	}

	.btn-loading {
		display: inline-flex;
		align-items: center;
	}

	.spinner {
		animation: spin 1s linear infinite;
	}

	@keyframes spin {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	.form-note {
		font-size: 13px;
		color: var(--muted);
		margin: 12px 0 0;
	}

	.success-message,
	.warning-message {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		padding: 16px 24px;
		border-radius: 12px;
		font-size: 16px;
		font-weight: 500;
		max-width: 400px;
		margin: 0 auto;
	}

	.success-message {
		background: rgba(34, 197, 94, 0.1);
		color: #22c55e;
	}

	.warning-message {
		background: rgba(245, 158, 11, 0.1);
		color: #f59e0b;
		margin-top: 16px;
	}

	.platform-note {
		font-size: 14px;
		color: var(--muted);
		margin: 32px 0 0;
	}

	.slack-link {
		color: #b5742d;
		text-decoration: none;
		font-weight: 600;
		transition: color 0.15s ease;
	}

	.slack-link:hover {
		color: #c9864a;
		text-decoration: underline;
	}

	.footer {
		padding: 60px 24px;
		background: var(--bg);
		width: 100vw;
		margin-left: calc(-50vw + 50%);
	}

	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 40px;
	}

	.footer-col {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.footer-col h4 {
		margin: 0 0 8px;
		font-size: 14px;
		font-weight: 700;
		color: #b5742d;
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	.footer-col a {
		color: var(--muted);
		text-decoration: none;
		font-size: 14px;
		transition: color 0.15s ease;
	}

	.footer-col a:hover {
		color: var(--text);
	}

	.footer-brand {
		align-items: flex-end;
		text-align: right;
	}

	.footer-logo {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		color: var(--text);
	}

	.footer-logo img {
		height: 36px;
		width: auto;
		border-radius: 8px;
	}

	.footer-brandName {
		font-family: 'Nunito', sans-serif;
		font-size: 18px;
		font-weight: 800;
		font-style: italic;
		color: var(--text);
	}

	.footer-socials {
		display: flex;
		gap: 16px;
		margin-top: 16px;
	}

	.footer-socials a {
		color: var(--muted);
		transition: color 0.15s ease;
	}

	.footer-socials a:hover {
		color: #b5742d;
	}


	@media (max-width: 800px) {
		.desktop-only {
			display: none;
		}

		.mobile-only {
			display: block;
		}

		.platform-content {
			padding: 40px 24px;
		}

		.platform-left h1 {
			font-size: 22px;
		}

		.platform-subtitle {
			font-size: 15px;
		}

		.form-group {
			flex-direction: column;
		}

		.email-input,
		.submit-btn {
			width: 100%;
		}

		.footer-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.footer-brand {
			grid-column: span 2;
			align-items: center;
			text-align: center;
		}

		.footer-socials {
			justify-content: center;
		}
	}
</style>
