---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { LINKS } from '../lib/constants';
---

<Layout title="Select Platform — Cookie" description="Add Cookie to your Slack workspace or Microsoft Teams in seconds. Free to try, no credit card required.">
	<div class="platform-page">
		<div class="platform-header">
			<ThemeToggle />
		</div>
		<div class="platform-card">
			<div class="platform-content">
				<div class="platform-left">
					<a href="/" class="platform-logo">
						<img src="/logo.png" alt="Cookie" width="40" height="40" />
						<span>Cookie</span>
					</a>

					<h1>Ready to <span class="highlight">Connect</span> Everyone?</h1>
					<p class="platform-subtitle">Build stronger teams with <strong>meaningful connections</strong>.</p>

					<div class="platform-buttons">
						<a href={LINKS.SLACK_APP} class="platform-btn slack-btn">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
								<path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z" fill="#E01E5A"/>
								<path d="M8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312z" fill="#36C5F0"/>
								<path d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.27 0a2.528 2.528 0 0 1-2.522 2.521 2.528 2.528 0 0 1-2.521-2.521V2.522A2.528 2.528 0 0 1 15.165 0a2.528 2.528 0 0 1 2.521 2.522v6.312z" fill="#2EB67D"/>
								<path d="M15.165 18.956a2.528 2.528 0 0 1 2.521 2.522A2.528 2.528 0 0 1 15.165 24a2.528 2.528 0 0 1-2.521-2.522v-2.522h2.521zm0-1.27a2.528 2.528 0 0 1-2.521-2.522 2.528 2.528 0 0 1 2.521-2.521h6.313A2.528 2.528 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.521h-6.313z" fill="#ECB22E"/>
							</svg>
							Get started with Slack
						</a>
						<a href={LINKS.TEAMS_APP} class="platform-btn teams-btn">
							<img src="/teams.svg" alt="Microsoft Teams" width="24" height="24" />
							Get started with Teams
						</a>
					</div>

					<p class="platform-note">Free to try. No credit card required. Fast setup.</p>
				</div>

			</div>
		</div>

		<footer class="footer">
			<div class="footer-inner">
				<div class="footer-grid">
					<div class="footer-col">
						<h4>About</h4>
						<a href="/docs/introduction/">Introduction</a>
						<a href="/docs/getting-started/setup/">Getting Started</a>
					</div>
					<div class="footer-col">
						<h4>Resources</h4>
						<a href="/docs/introduction/">Documentation</a>
						<a href="/docs/getting-started/need-help/">Help</a>
						<a href="/docs/getting-started/faq/">FAQ</a>
					</div>
					<div class="footer-col">
						<h4>Legal</h4>
						<a href="/docs/legal/privacy-policy/">Privacy Policy</a>
						<a href="/docs/legal/terms-of-service/">Terms of Service</a>
					</div>
					<div class="footer-col footer-brand">
						<a class="footer-logo" href="/" aria-label="Cookie home">
							<img src="/logo.png" width="128" height="85" alt="Cookie" />
							<span class="footer-brandName">Cookie</span>
						</a>
						<div class="footer-socials">
							<a href={LINKS.TWITTER} target="_blank" rel="noreferrer" aria-label="X (Twitter)">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
									<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
								</svg>
							</a>
						</div>
					</div>
				</div>
			</div>
		</footer>
	</div>
</Layout>

<style>
	.platform-page {
		min-height: 100vh;
		background: var(--bg-secondary);
		display: flex;
		flex-direction: column;
	}

	.platform-header {
		display: flex;
		justify-content: flex-end;
		padding: 20px 40px;
		max-width: 1200px;
		margin: 0 auto;
		width: 100%;
	}

	.platform-card {
		flex: 1;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding: 40px 24px 80px;
	}

	.platform-content {
		background: var(--bg);
		border-radius: 24px;
		padding: 60px;
		max-width: 700px;
		width: 100%;
		box-shadow: var(--shadow);
		text-align: center;
	}

	.platform-logo {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		text-decoration: none;
		color: var(--text);
		margin-bottom: 40px;
	}

	.platform-logo img {
		border-radius: 8px;
	}

	.platform-logo span {
		font-family: 'Nunito', sans-serif;
		font-size: 24px;
		font-weight: 800;
		font-style: italic;
	}

	.platform-left h1 {
		font-size: 42px;
		font-weight: 800;
		line-height: 1.1;
		color: var(--text);
		margin: 0 0 16px;
		white-space: nowrap;
	}

	.platform-left h1 .highlight {
		color: #b5742d;
	}

	.platform-subtitle {
		font-size: 18px;
		color: var(--muted);
		margin: 0 0 32px;
	}

	.platform-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		padding: 16px 32px;
		border-radius: 12px;
		font-size: 18px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.2s ease;
		width: 100%;
		max-width: 300px;
	}

	.platform-buttons {
		display: flex;
		flex-direction: column;
		gap: 12px;
		align-items: center;
	}

	.slack-btn {
		background: #611f64;
		color: white;
	}

	.slack-btn:hover {
		background: #7a3b7d;
		transform: translateY(-2px);
	}

	.teams-btn {
		background: #6264d4;
		color: white;
	}

	.teams-btn:hover {
		background: #7b7de0;
		transform: translateY(-2px);
	}

	.platform-note {
		font-size: 14px;
		color: var(--muted);
		margin: 16px 0 0;
	}

	.platform-right {
		display: flex;
		align-items: center;
	}

	.companies-box {
		border: 2px solid var(--border);
		border-radius: 16px;
		padding: 32px;
		width: 100%;
	}

	.companies-box h3 {
		font-size: 18px;
		font-weight: 700;
		color: var(--text);
		text-align: center;
		margin: 0 0 24px;
	}

	.companies-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
	}

	.company-placeholder {
		background: var(--bg-secondary);
		border-radius: 8px;
		padding: 16px;
		text-align: center;
		font-size: 12px;
		color: var(--muted);
	}

	.footer {
		padding: 60px 24px;
		background: var(--bg);
		width: 100vw;
		margin-left: calc(-50vw + 50%);
	}

	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 40px;
	}

	.footer-col {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.footer-col h4 {
		margin: 0 0 8px;
		font-size: 14px;
		font-weight: 700;
		color: #b5742d;
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	.footer-col a {
		color: var(--muted);
		text-decoration: none;
		font-size: 14px;
		transition: color 0.15s ease;
	}

	.footer-col a:hover {
		color: var(--text);
	}

	.footer-brand {
		align-items: flex-end;
		text-align: right;
	}

	.footer-logo {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		color: var(--text);
	}

	.footer-logo img {
		height: 36px;
		width: auto;
		border-radius: 8px;
	}

	.footer-brandName {
		font-family: 'Nunito', sans-serif;
		font-size: 18px;
		font-weight: 800;
		font-style: italic;
		color: var(--text);
	}

	.footer-socials {
		display: flex;
		gap: 16px;
		margin-top: 16px;
	}

	.footer-socials a {
		color: var(--muted);
		transition: color 0.15s ease;
	}

	.footer-socials a:hover {
		color: #b5742d;
	}


	@media (max-width: 800px) {
		.platform-content {
			grid-template-columns: 1fr;
			padding: 40px 24px;
		}

		.platform-left h1 {
			font-size: 28px;
			white-space: normal;
		}

		.platform-subtitle {
			font-size: 15px;
		}

		.platform-btn {
			padding: 12px 24px;
			font-size: 16px;
			max-width: 240px;
		}

		.platform-note {
			font-size: 12px;
		}

		.platform-right {
			display: none;
		}

		.footer-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.footer-brand {
			grid-column: span 2;
			align-items: center;
			text-align: center;
		}

		.footer-socials {
			justify-content: center;
		}
	}
</style>
